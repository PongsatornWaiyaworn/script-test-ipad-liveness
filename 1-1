// MARK: - Performance Metrics Model
struct InferenceMetrics {
    var inferenceTimeMs: Double = 0
    var preprocessTimeMs: Double = 0
    var totalTimeMs: Double = 0
    var cpuUsageBefore: Double = 0
    var cpuUsageAfter: Double = 0
    var memoryUsedMB: Double = 0
    var predictedClass: String = "-"
    var confidence: Float = 0
    var allClassScores: [(label: String, confidence: Float)] = []
}

// MARK: - Resource Monitor
class ResourceMonitor {
    static func getCPUUsage() -> Double {
        var info = host_cpu_load_info()
        var count = mach_msg_type_number_t(
            MemoryLayout<host_cpu_load_info_data_t>.size / MemoryLayout<integer_t>.size
        )
        let result = withUnsafeMutablePointer(to: &info) {
            $0.withMemoryRebound(to: integer_t.self, capacity: Int(count)) {
                host_statistics(mach_host_self(), HOST_CPU_LOAD_INFO, $0, &count)
            }
        }
        guard result == KERN_SUCCESS else { return 0 }
        let user   = Double(info.cpu_ticks.0)
        let system = Double(info.cpu_ticks.1)
        let idle   = Double(info.cpu_ticks.2)
        let nice   = Double(info.cpu_ticks.3)
        let total  = user + system + idle + nice
        guard total > 0 else { return 0 }
        return ((user + system + nice) / total) * 100.0
    }

    static func getMemoryUsageMB() -> Double {
        var info = mach_task_basic_info()
        var count = mach_msg_type_number_t(
            MemoryLayout<mach_task_basic_info_data_t>.size / MemoryLayout<natural_t>.size
        )
        let result = withUnsafeMutablePointer(to: &info) {
            $0.withMemoryRebound(to: integer_t.self, capacity: Int(count)) {
                task_info(mach_task_self_, task_flavor_t(MACH_TASK_BASIC_INFO), $0, &count)
            }
        }
        guard result == KERN_SUCCESS else { return 0 }
        return Double(info.resident_size) / 1_048_576.0
    }
}

// MARK: - Liveness Classifier
class LivenessClassifier: ObservableObject {
    @Published var metrics = InferenceMetrics()
    @Published var isProcessing = false
    @Published var errorMessage: String? = nil
    @Published var modelStatus: String = "กำลังโหลดโมเดล…"

    // ── แก้ตรงนี้จุดเดียว: ชื่อไฟล์ .mlmodel (ไม่ใส่นามสกุล) ──
    private let modelFileName = "MobileNetV3_liveness"

    @Published var vnRequest: VNCoreMLRequest?

    init() {
        DispatchQueue.global(qos: .userInitiated).async { [weak self] in
            self?.setupModel()
        }
    }

    // MARK: - Setup
    private func setupModel() {
        do {
            guard let modelURL = Bundle.main.url(forResource: modelFileName,
                                                  withExtension: "mlmodel") else {
                throw ModelError.modelNotFound(modelFileName)
            }

            setStatus("กำลัง compile โมเดล…")
            let compiledURL = try MLModel.compileModel(at: modelURL)

            setStatus("โหลดโมเดล…")
            let config = MLModelConfiguration()
            config.computeUnits = .all

            let mlModel = try MLModel(contentsOf: compiledURL, configuration: config)
            let vnModel = try VNCoreMLModel(for: mlModel)

            let request = VNCoreMLRequest(model: vnModel)
            request.imageCropAndScaleOption = .centerCrop
            self.vnRequest = request

            DispatchQueue.main.async {
                self.modelStatus  = "✅ โมเดลพร้อมใช้งาน"
                self.errorMessage = nil
            }

        } catch ModelError.modelNotFound(let name) {
            setError("❌ ไม่พบ \(name).mlmodel ใน bundle\nลากไฟล์ .mlmodel เข้า Swift Playgrounds แล้วรันใหม่")
        } catch {
            let ns = error as NSError
            setError("Domain: \(ns.domain)\nCode: \(ns.code)\n\(ns.localizedDescription)")
        }
    }

    private func setStatus(_ msg: String) {
        DispatchQueue.main.async { self.modelStatus = msg }
    }
    private func setError(_ msg: String) {
        DispatchQueue.main.async {
            self.errorMessage = msg
            self.modelStatus  = "❌ โหลดล้มเหลว"
        }
    }

    enum ModelError: Error {
        case modelNotFound(String)
    }

    // MARK: - Main Entry Point
    func analyzeImage(_ image: UIImage) {
        guard !isProcessing else { return }
        isProcessing = true
        errorMessage = nil

        DispatchQueue.global(qos: .userInitiated).async { [weak self] in
            guard let self else { return }
            if self.vnRequest != nil {
                self.runVisionInference(image)
            } else {
                self.runDemoInference(image)
            }
        }
    }

    // MARK: - Real Vision Inference
    private func runVisionInference(_ image: UIImage) {
        guard let request = vnRequest,
              let cgImage = image.cgImage else {
            finishWithError("ไม่สามารถเตรียมภาพสำหรับ inference ได้")
            return
        }

        var result = InferenceMetrics()
        result.cpuUsageBefore = ResourceMonitor.getCPUUsage()

        let preStart = Date()
        let handler = VNImageRequestHandler(cgImage: cgImage, options: [:])
        result.preprocessTimeMs = Date().timeIntervalSince(preStart) * 1000

        let inferStart = Date()
        do {
            try handler.perform([request])
        } catch {
            finishWithError("Inference error: \(error.localizedDescription)")
            return
        }
        result.inferenceTimeMs = Date().timeIntervalSince(inferStart) * 1000
        result.totalTimeMs = result.preprocessTimeMs + result.inferenceTimeMs

        result.cpuUsageAfter = ResourceMonitor.getCPUUsage()
        result.memoryUsedMB  = ResourceMonitor.getMemoryUsageMB()

        if let observations = request.results as? [VNClassificationObservation] {
            result.allClassScores = observations.map { ($0.identifier, $0.confidence) }
            if let top = observations.first {
                result.predictedClass = top.identifier
                result.confidence     = top.confidence
            }
        }

        finishWithResult(result)
    }

    // MARK: - Demo Inference (fallback เมื่อยังไม่มีโมเดล)
    private func runDemoInference(_ image: UIImage) {
        var result = InferenceMetrics()
        result.cpuUsageBefore = ResourceMonitor.getCPUUsage()

        let preStart = Date()
        _ = image.jpegData(compressionQuality: 0.8)
        result.preprocessTimeMs = Date().timeIntervalSince(preStart) * 1000

        let inferStart = Date()
        Thread.sleep(forTimeInterval: Double.random(in: 0.08...0.20))
        result.inferenceTimeMs = Date().timeIntervalSince(inferStart) * 1000
        result.totalTimeMs = result.preprocessTimeMs + result.inferenceTimeMs

        result.cpuUsageAfter = ResourceMonitor.getCPUUsage()
        result.memoryUsedMB  = ResourceMonitor.getMemoryUsageMB()

        let liveConf  = Float.random(in: 0.65...0.95)
        let spoofConf = 1.0 - liveConf
        result.allClassScores = [("live", liveConf), ("spoof", spoofConf)]
        result.predictedClass = "live"
        result.confidence     = liveConf

        finishWithResult(result)
    }

    private func finishWithResult(_ result: InferenceMetrics) {
        DispatchQueue.main.async { [weak self] in
            self?.metrics      = result
            self?.isProcessing = false
        }
    }

    private func finishWithError(_ msg: String) {
        DispatchQueue.main.async { [weak self] in
            self?.errorMessage = msg
            self?.isProcessing = false
        }
    }
}

// MARK: - Camera / Photo Picker
struct ImagePicker: UIViewControllerRepresentable {
    @Binding var selectedImage: UIImage?
    @Environment(\.dismiss) var dismiss
    var sourceType: UIImagePickerController.SourceType

    func makeUIViewController(context: Context) -> UIImagePickerController {
        let picker = UIImagePickerController()
        picker.sourceType = sourceType
        picker.delegate = context.coordinator
        return picker
    }
    func updateUIViewController(_ uvc: UIImagePickerController, context: Context) {}

    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, UINavigationControllerDelegate, UIImagePickerControllerDelegate {
        let parent: ImagePicker
        init(_ p: ImagePicker) { parent = p }
        func imagePickerController(_ picker: UIImagePickerController,
                                   didFinishPickingMediaWithInfo info: [UIImagePickerController.InfoKey: Any]) {
            parent.selectedImage = info[.originalImage] as? UIImage
            parent.dismiss()
        }
        func imagePickerControllerDidCancel(_ picker: UIImagePickerController) {
            parent.dismiss()
        }
    }
}

// MARK: - Metrics Card
struct MetricCard: View {
    let title: String
    let value: String
    let icon: String
    var accent: Color = .blue

    var body: some View {
        VStack(spacing: 6) {
            Image(systemName: icon)
                .font(.title2)
                .foregroundColor(accent)
            Text(value)
                .font(.headline).bold()
            Text(title)
                .font(.caption)
                .foregroundColor(.secondary)
                .multilineTextAlignment(.center)
        }
        .frame(maxWidth: .infinity)
        .padding(12)
        .background(Color(.secondarySystemBackground))
        .cornerRadius(12)
    }
}

// MARK: - Main View
struct ContentView: View {
    @StateObject private var classifier = LivenessClassifier()
    @State private var capturedImage: UIImage? = nil
    @State private var showCamera = false
    @State private var showPhotoPicker = false

    private var resultColor: Color {
        switch classifier.metrics.predictedClass.lowercased() {
        case "live":  return .green
        case "spoof": return .red
        default:      return .gray
        }
    }

    var body: some View {
        NavigationView {
            ScrollView {
                VStack(spacing: 20) {

                    // ── Model status banner ──────────────────────────────
                    HStack(spacing: 8) {
                        if classifier.vnRequest == nil && classifier.errorMessage == nil {
                            ProgressView().scaleEffect(0.8)
                        }
                        Text(classifier.modelStatus)
                            .font(.footnote)
                            .foregroundColor(
                                classifier.modelStatus.hasPrefix("✅") ? .green : .secondary
                            )
                    }
                    .frame(maxWidth: .infinity)
                    .padding(8)
                    .background(Color(.secondarySystemBackground))
                    .cornerRadius(8)
                    .padding(.horizontal)

                    // ── Error banner ─────────────────────────────────────
                    if let err = classifier.errorMessage {
                        Text(err)
                            .font(.footnote)
                            .foregroundColor(.orange)
                            .multilineTextAlignment(.center)
                            .padding(10)
                            .background(Color.orange.opacity(0.1))
                            .cornerRadius(10)
                            .padding(.horizontal)
                    }

                    // ── Preview ──────────────────────────────────────────
                    ZStack {
                        RoundedRectangle(cornerRadius: 16)
                            .fill(Color(.tertiarySystemBackground))
                            .frame(height: 300)

                        if let img = capturedImage {
                            Image(uiImage: img)
                                .resizable()
                                .scaledToFill()
                                .frame(height: 300)
                                .clipped()
                                .cornerRadius(16)
                        } else {
                            VStack(spacing: 8) {
                                Image(systemName: "camera.viewfinder")
                                    .font(.system(size: 60))
                                    .foregroundColor(.secondary)
                                Text("ถ่ายรูปหรือเลือกจาก Library")
                                    .foregroundColor(.secondary)
                            }
                        }

                        if classifier.isProcessing {
                            RoundedRectangle(cornerRadius: 16)
                                .fill(Color.black.opacity(0.45))
                                .frame(height: 300)
                            VStack(spacing: 10) {
                                ProgressView().tint(.white).scaleEffect(1.4)
                                Text("กำลังประมวลผล…").foregroundColor(.white).font(.headline)
                            }
                        }
                    }
                    .padding(.horizontal)

                    // ── Capture buttons ──────────────────────────────────
                    HStack(spacing: 12) {
                        Button {
                            if UIImagePickerController.isSourceTypeAvailable(.camera) {
                                showCamera = true
                            }
                        } label: {
                            Label("ถ่ายรูป", systemImage: "camera.fill")
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(Color.blue)
                                .foregroundColor(.white)
                                .cornerRadius(12)
                        }

                        Button { showPhotoPicker = true } label: {
                            Label("Library", systemImage: "photo.on.rectangle")
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(Color.purple)
                                .foregroundColor(.white)
                                .cornerRadius(12)
                        }
                    }
                    .padding(.horizontal)

                    // ── Analyse button ───────────────────────────────────
                    if capturedImage != nil && !classifier.isProcessing {
                        Button {
                            guard let img = capturedImage else { return }
                            classifier.analyzeImage(img)
                        } label: {
                            Label("วิเคราะห์ภาพ", systemImage: "waveform.path.ecg")
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(Color.green)
                                .foregroundColor(.white)
                                .cornerRadius(12)
                                .bold()
                        }
                        .padding(.horizontal)
                    }

                    // ── Result banner ────────────────────────────────────
                    if classifier.metrics.predictedClass != "-" {
                        VStack(spacing: 4) {
                            Text(classifier.metrics.predictedClass.uppercased())
                                .font(.system(size: 34, weight: .black))
                                .foregroundColor(resultColor)
                            Text(String(format: "Confidence: %.1f%%",
                                        classifier.metrics.confidence * 100))
                                .font(.title3)
                                .foregroundColor(.secondary)
                        }
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(resultColor.opacity(0.1))
                        .cornerRadius(16)
                        .padding(.horizontal)
                    }

                    // ── Metrics grid ─────────────────────────────────────
                    if classifier.metrics.totalTimeMs > 0 {
                        VStack(alignment: .leading, spacing: 12) {
                            Text("⚡ Performance Metrics")
                                .font(.headline)
                                .padding(.horizontal)

                            LazyVGrid(
                                columns: [GridItem(.flexible()), GridItem(.flexible()), GridItem(.flexible())],
                                spacing: 10
                            ) {
                                MetricCard(title: "Pre-process",
                                           value: String(format: "%.1f ms", classifier.metrics.preprocessTimeMs),
                                           icon: "photo.circle", accent: .orange)
                                MetricCard(title: "Inference",
                                           value: String(format: "%.1f ms", classifier.metrics.inferenceTimeMs),
                                           icon: "cpu", accent: .blue)
                                MetricCard(title: "Total",
                                           value: String(format: "%.1f ms", classifier.metrics.totalTimeMs),
                                           icon: "timer", accent: .green)
                                MetricCard(title: "CPU Before",
                                           value: String(format: "%.1f%%", classifier.metrics.cpuUsageBefore),
                                           icon: "speedometer", accent: .teal)
                                MetricCard(title: "CPU After",
                                           value: String(format: "%.1f%%", classifier.metrics.cpuUsageAfter),
                                           icon: "speedometer", accent: .red)
                                MetricCard(title: "Memory",
                                           value: String(format: "%.1f MB", classifier.metrics.memoryUsedMB),
                                           icon: "memorychip", accent: .purple)
                            }
                            .padding(.horizontal)

                            // ── Class scores ─────────────────────────────
                            if !classifier.metrics.allClassScores.isEmpty {
                                VStack(alignment: .leading, spacing: 8) {
                                    Text("Class Scores")
                                        .font(.subheadline).bold()
                                        .foregroundColor(.secondary)

                                    ForEach(classifier.metrics.allClassScores, id: \.label) { item in
                                        HStack {
                                            Text(item.label)
                                                .frame(width: 120, alignment: .leading)
                                                .font(.footnote)
                                            GeometryReader { geo in
                                                ZStack(alignment: .leading) {
                                                    Capsule().fill(Color(.systemFill))
                                                    Capsule()
                                                        .fill(item.label == classifier.metrics.predictedClass
                                                              ? resultColor : Color.blue.opacity(0.6))
                                                        .frame(width: geo.size.width * CGFloat(item.confidence))
                                                }
                                            }
                                            .frame(height: 10)
                                            Text(String(format: "%.1f%%", item.confidence * 100))
                                                .font(.caption).bold()
                                                .frame(width: 52, alignment: .trailing)
                                        }
                                    }
                                }
                                .padding()
                                .background(Color(.secondarySystemBackground))
                                .cornerRadius(12)
                                .padding(.horizontal)
                            }
                        }
                    }

                    Spacer(minLength: 40)
                }
                .padding(.top)
            }
            .navigationTitle("Liveness Detection")
            .navigationBarTitleDisplayMode(.inline)
        }
        .navigationViewStyle(.stack)
        .sheet(isPresented: $showCamera) {
            ImagePicker(selectedImage: $capturedImage, sourceType: .camera)
        }
        .sheet(isPresented: $showPhotoPicker) {
            ImagePicker(selectedImage: $capturedImage, sourceType: .photoLibrary)
        }
    }
}
